{
  "name": "kavanah",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^expo-crypto$": "<rootDir>/src/test/expoCryptoMock.ts",
      "^expo-secure-store$": "<rootDir>/src/test/expoSecureStoreMock.ts",
      "^react-native-mmkv$": "<rootDir>/src/test/mmkvMock.ts"
    }
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "date-fns": "^4.1.0",
    "expo": "^53.0.0",
    "expo-apple-authentication": "^7.2.4",
    "expo-application": "^6.1.4",
    "expo-crypto": "^14.1.5",
    "expo-device": "^7.1.4",
    "expo-local-authentication": "^16.0.5",
    "expo-location": "^18.1.6",
    "expo-notifications": "^0.31.4",
    "expo-secure-store": "^14.2.3",
    "expo-status-bar": "^2.2.3",
    "kosher-zmanim": "^0.9.0",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-expo": "^9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "^53.0.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "19.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "typescript": "~5.8.3"
  }
}
